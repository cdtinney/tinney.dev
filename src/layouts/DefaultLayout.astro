---
import ScrollToTop from '../components/ScrollToTop.astro';
import ThemeSwitcher from '../components/ThemeSwitcher.astro';
import '../styles/global.css';
import { themes } from '../themes/index.js';

interface Props {
  title?: string;
  description?: string;
  ogType?: string;
}

const {
  title = 'colin tinney',
  description = 'A personal website',
  ogType = 'website',
} = Astro.props;
const pageTitle = title === 'colin tinney' ? title : `${title} | colin tinney`;
const canonicalUrl = new URL(Astro.url.pathname, 'https://tinney.dev').href;
const ogImageUrl = new URL('/og-image.png', 'https://tinney.dev').href;

// Build-time: collect theme CSS, base CSS, and HTML from all themes
const themeEntries = Object.entries(themes);
const themeCssBlocks = themeEntries
  .filter(([_, t]) => t.css)
  .map(([_, t]) => t.css)
  .join('\n');
const themeBaseCss = themeEntries
  .filter(([_, t]) => t.baseCss)
  .map(([_, t]) => t.baseCss)
  .join('\n');
const themeHtml = themeEntries
  .filter(([_, t]) => t.html)
  .map(([_, t]) => t.html)
  .join('\n');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="colin tinney" />
    <meta property="og:image" content={ogImageUrl} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <!-- Theme CSS rendered at build time — activated by data-theme attribute -->
    <style set:html={themeCssBlocks}></style>
    <script is:inline>
      /* eslint-disable no-var, no-empty */
      // Apply saved theme before first paint to prevent flash
      (function () {
        try {
          var match = document.cookie.match(/(?:^|; )theme=([^;]+)/);
          var themeId = match && match[1];
          if (!themeId || themeId === 'default') return;
          var themes = {
            sharks: {
              '--color-text': '#e8e8e8',
              '--color-text-secondary': '#a0b4b6',
              '--color-text-muted': '#c0cfd0',
              '--color-text-muted-hover': '#EA7200',
              '--color-bg': '#004a50',
              '--color-bg-surface': '#005a62',
              '--color-primary': '#EA7200',
              '--color-primary-hover': '#ff9224',
              '--color-secondary': '#ff9224',
              '--color-secondary-hover': '#ffb366',
              '--color-secondary-border': '#EA7200',
              '--color-accent': '#EA7200',
              '--color-border': 'rgba(234, 114, 0, 0.4)',
              '--color-code-bg': '#003a3f',
              '--color-code-text': '#e0c8a8',
              '--shadow-button': '0 2px 6px rgba(0, 0, 0, 0.3), 0 2px 4px rgba(0, 0, 0, 0.2)',
            },
            underwater: {
              '--color-text': '#d4f1f9',
              '--color-text-secondary': '#7ec8d9',
              '--color-text-muted': '#a8dce6',
              '--color-text-muted-hover': '#00b894',
              '--color-bg': '#0a2942',
              '--color-bg-surface': '#0e3654',
              '--color-primary': '#00b894',
              '--color-primary-hover': '#00d6a8',
              '--color-secondary': '#f9ca24',
              '--color-secondary-hover': '#fad961',
              '--color-secondary-border': '#d4a818',
              '--color-accent': '#00b894',
              '--color-border': 'rgba(0, 184, 148, 0.3)',
              '--color-code-bg': '#071e30',
              '--color-code-text': '#7ec8d9',
              '--shadow-button': '0 2px 8px rgba(0, 0, 0, 0.4), 0 2px 4px rgba(0, 41, 66, 0.3)',
            },
            canada: {
              '--color-text': '#ffffff',
              '--color-text-secondary': '#ffcccc',
              '--color-text-muted': '#ffd4d4',
              '--color-text-muted-hover': '#ffffff',
              '--color-bg': '#FF0000',
              '--color-bg-surface': '#cc0000',
              '--color-primary': '#ffffff',
              '--color-primary-hover': '#ffe0e0',
              '--color-secondary': '#ffffff',
              '--color-secondary-hover': '#ffe0e0',
              '--color-secondary-border': '#ffffff',
              '--color-accent': '#ffffff',
              '--color-border': 'rgba(255, 255, 255, 0.4)',
              '--color-code-bg': '#b30000',
              '--color-code-text': '#ffe0e0',
              '--shadow-button': '0 2px 6px rgba(0, 0, 0, 0.3), 0 2px 4px rgba(0, 0, 0, 0.2)',
            },
          };
          var colors = themes[themeId];
          if (!colors) return;
          var root = document.documentElement;
          root.dataset.theme = themeId;
          for (var prop in colors) {
            root.style.setProperty(prop, colors[prop]);
          }
        } catch {}
      })();
    </script>
  </head>
  <body>
    <main class="content">
      <slot />
    </main>
    <ScrollToTop />
    <ThemeSwitcher />

    <!-- Theme elements rendered at build time -->
    <Fragment set:html={themeHtml} />

    <!-- Initialize active theme's client-side logic -->
    <script>
      import { applyTheme, getStoredThemeId } from '../themes/index.js';
      applyTheme(getStoredThemeId() || 'default');
    </script>
  </body>
</html>

<style>
  .content {
    display: flex;
    flex-direction: column;
    flex: 1;
  }
</style>

<!-- Theme base CSS (structural styles for hidden elements) rendered at build time -->
<style is:global set:html={themeBaseCss}></style>
