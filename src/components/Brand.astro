---
import { site } from '../data/site';
import { secretPages } from '../data/secret';

interface Props {
  title?: string;
  large?: boolean;
  underline?: boolean;
  class?: string;
}

const { title = site.title, large = false, underline = true, class: className = '' } = Astro.props;
const headerClass = [
  'header',
  large ? 'header-large' : '',
  underline ? 'header-underline' : '',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<h1 class={headerClass}>
  <a href="/" class="link" data-brand>{title}</a>
  <div class="secret-dropdown dropdown-menu flex-col" data-secret-dropdown>
    {
      secretPages.map((page) => (
        <a href={page.path} class="secret-link link-quiet">
          {page.name}
        </a>
      ))
    }
  </div>
</h1>

<script>
  import { onMultiTap } from '../utils/multiTap';

  const isHomePage = globalThis.location.pathname === '/';
  const brand = document.querySelector<HTMLElement>('[data-brand]');
  const dropdown = document.querySelector<HTMLElement>('[data-secret-dropdown]');

  if (isHomePage && brand && dropdown) {
    const show = () => {
      dropdown.dataset.visible = '';
    };
    const hide = () => {
      delete dropdown.dataset.visible;
    };
    const toggle = () => ('visible' in dropdown.dataset ? hide() : show());

    // Hover for 3 seconds
    let hoverTimer: ReturnType<typeof setTimeout> | null = null;
    brand.addEventListener('mouseenter', () => {
      hoverTimer = setTimeout(show, 3000);
    });
    brand.addEventListener('mouseleave', () => {
      if (hoverTimer) clearTimeout(hoverTimer);
    });

    // Triple tap (only on home page)
    onMultiTap(brand, toggle, { taps: 3 });

    // Close when clicking outside
    document.addEventListener('click', (e) => {
      if (!brand.closest('h1')?.contains(e.target as Node)) hide();
    });
  }
</script>

<style>
  .header {
    display: inline-block;
    margin: 0;
    padding: 0 4px;
    cursor: default;
    position: relative;
  }

  .header-large {
    font-size: 3em;
    margin-bottom: 0;
    text-shadow: 0.5px 0.5px 1px var(--color-secondary);
  }

  .header-underline {
    border-bottom: 1px solid var(--color-border);
  }

  .link {
    color: var(--color-text) !important;
    text-decoration: none;
  }

  .link:hover {
    color: var(--color-text-secondary) !important;
  }

  [data-secret-dropdown] {
    top: 100%;
    left: 0;
    min-width: 80px;
  }

  [data-secret-dropdown][data-visible] {
    display: flex;
  }

  .secret-link {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-sm);
  }

  .secret-link:hover {
    color: var(--color-text);
    background: var(--color-border);
  }

  @media (max-width: 576px) {
    .header:not(.header-large) {
      font-size: 1.2rem;
    }
  }
</style>
