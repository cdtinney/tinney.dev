---
interface Props {
  title?: string;
  large?: boolean;
  underline?: boolean;
  class?: string;
}

const { title = 'colin tinney', large = false, underline = true, class: className = '' } = Astro.props;
const headerClass = [
  'header',
  large ? 'header-large' : '',
  underline ? 'header-underline' : '',
  className,
].filter(Boolean).join(' ');
---

<h1 class={headerClass}>
  <a href="/" class="link">{title}</a>
</h1>

<style>
  .header {
    display: inline-block;
    margin: 0;
    padding: 0 4px;
    cursor: default;
  }

  .header-large {
    font-size: 3em;
    margin-bottom: 0;
    text-shadow: 0.5px 0.5px 1px rgb(216, 95, 79);
  }

  .header-underline {
    border-bottom: 1px solid #828282;
  }

  .link {
    color: rgb(33, 32, 40) !important;
    text-decoration: none;
  }

  .link:hover {
    color: rgb(96, 94, 110) !important;
  }

  @media (max-width: 576px) {
    .header:not(.header-large) {
      font-size: 1.2rem;
    }
  }
</style>
