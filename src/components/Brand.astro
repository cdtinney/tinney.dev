---
interface Props {
  title?: string;
  large?: boolean;
  underline?: boolean;
  class?: string;
}

const {
  title = 'colin tinney',
  large = false,
  underline = true,
  class: className = '',
} = Astro.props;
const headerClass = [
  'header',
  large ? 'header-large' : '',
  underline ? 'header-underline' : '',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<h1 class={headerClass}>
  <a href="/" class="link">{title}</a>
</h1>

<style>
  .header {
    display: inline-block;
    margin: 0;
    padding: 0 4px;
    cursor: default;
  }

  .header-large {
    font-size: 3em;
    margin-bottom: 0;
    text-shadow: 0.5px 0.5px 1px var(--color-secondary);
  }

  .header-underline {
    border-bottom: 1px solid var(--color-border);
  }

  .link {
    color: var(--color-text) !important;
    text-decoration: none;
  }

  .link:hover {
    color: var(--color-text-secondary) !important;
  }

  @media (max-width: 576px) {
    .header:not(.header-large) {
      font-size: 1.2rem;
    }
  }
</style>
