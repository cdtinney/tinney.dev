---
interface Props {
  href: string;
  external?: boolean;
  text: string;
  color?: 'primary' | 'secondary';
  class?: string;
}

const { href, external = false, text, color = 'primary', class: className = '' } = Astro.props;
const colorClass = color === 'secondary' ? 'btn-secondary' : 'btn-primary';
const classes = `anchor-button ${colorClass} ${className}`.trim();
const externalProps = external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

<a href={href} class={classes} data-anchor-btn data-btn={color} {...externalProps}>
  {text}
</a>

<style>
  .anchor-button {
    position: relative;
    display: inline-block;
    width: 100px;
    margin: 0 0.5rem;
    padding: 6px;
    text-align: center;
    text-decoration: none;
    transition: top ease 1s, background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
    border-radius: 3px;
    border-width: var(--btn-border-width);
    border-style: solid;
    background-color: var(--color-bg-surface);
    box-shadow: var(--shadow-button);
  }

  .anchor-button:hover {
    top: -1px;
  }

  .btn-primary {
    color: var(--btn-primary-text);
    background-color: var(--btn-primary-bg);
    border-color: var(--btn-primary-border);
  }

  .btn-primary:hover {
    color: var(--btn-primary-text-hover);
    background-color: var(--btn-primary-bg-hover);
    border-color: var(--btn-primary-border-hover);
  }

  .btn-secondary {
    color: var(--btn-secondary-text);
    background-color: var(--btn-secondary-bg);
    border-color: var(--btn-secondary-border);
  }

  .btn-secondary:hover {
    color: var(--btn-secondary-text-hover);
    background-color: var(--btn-secondary-bg-hover);
    border-color: var(--btn-secondary-border-hover);
  }
</style>
