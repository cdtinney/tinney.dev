---
import Brand from './Brand.astro';
import { site } from '../data/site';

interface Props {
  title: string;
  siteTitle?: string;
}

const { title, siteTitle = site.title } = Astro.props;
---

<header class="header" data-header>
  <div class="bg-overlay"></div>
  <Brand underline={false} class="brand" title={siteTitle} />
  <span class="separator">/</span>
  <h3 class="title">{title}</h3>
  <nav class="desktop-menu">
    <a href="/blog" class="desktop-menu-item">blog</a>
    <a href="/projects" class="desktop-menu-item">projects</a>
  </nav>
  <span class="mobile-menu">
    <button class="hamburger-btn btn-reset" aria-label="Toggle menu" aria-expanded="false">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
    <nav class="mobile-dropdown">
      <a href="/blog" class="mobile-menu-item">blog</a>
      <a href="/projects" class="mobile-menu-item">projects</a>
    </nav>
  </span>
</header>

<script>
  const btn = document.querySelector('.hamburger-btn');
  const menu = document.querySelector('.mobile-dropdown');
  const overlay = document.querySelector('.bg-overlay');

  function closeMenu() {
    menu?.classList.remove('is-open');
    overlay?.classList.remove('is-visible');
    btn?.classList.remove('is-open');
    btn?.setAttribute('aria-expanded', 'false');
  }

  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('is-open');
    overlay?.classList.toggle('is-visible', open);
    btn?.classList.toggle('is-open', open);
    btn?.setAttribute('aria-expanded', String(!!open));
  });

  overlay?.addEventListener('click', closeMenu);
  window.addEventListener('resize', closeMenu);
  window.addEventListener('scroll', closeMenu);
</script>

<style>
  .header {
    display: flex;
    min-height: 50px;
    line-height: 50px;
    align-items: center;
    border-bottom: var(--header-border);
    transition: border-bottom var(--transition-normal) ease;
    position: relative;
  }

  .separator {
    margin: 0 10px;
  }

  .title {
    margin: 0;
    word-break: break-word;
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
  }

  .desktop-menu,
  .mobile-menu {
    margin-left: auto;
    padding: 1px 0;
  }

  .desktop-menu-item {
    font-size: 1.1em;
    margin: 0 0.5em;
  }

  .mobile-menu {
    display: none;
    z-index: 100;
  }

  .hamburger-btn {
    display: flex;
    flex-direction: column;
    justify-content: space-around;
    width: 24px;
    height: 20px;
    padding: 0;
  }

  .bar {
    display: block;
    width: 100%;
    height: 1px;
    background-color: var(--color-text);
    transition: all var(--transition-fast) ease;
    transform-origin: center;
  }

  .hamburger-btn.is-open .bar {
    background-color: var(--color-bg-surface);
  }

  .hamburger-btn.is-open .bar:nth-child(1) {
    transform: translateY(9px) rotate(45deg);
  }

  .hamburger-btn.is-open .bar:nth-child(2) {
    opacity: 0;
  }

  .hamburger-btn.is-open .bar:nth-child(3) {
    transform: translateY(-9px) rotate(-45deg);
  }

  .mobile-dropdown {
    display: none;
    position: fixed;
    top: 50px;
    left: 0;
    width: 100vw;
    flex-direction: column;
    align-items: flex-end;
    padding: 0.5em;
    font-size: 1.4rem;
    background-color: var(--color-bg-surface);
    box-shadow: var(--shadow-dropdown);
    z-index: 100;
  }

  .mobile-dropdown.is-open {
    display: flex;
  }

  .mobile-menu-item {
    padding: 0.5em;
  }

  .bg-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgb(75, 75, 75);
    opacity: 0;
    transition: opacity var(--transition-fast) ease-in-out;
    pointer-events: none;
    z-index: 50;
  }

  .bg-overlay.is-visible {
    opacity: 0.75;
    pointer-events: auto;
  }

  @media (max-width: 576px) {
    .header {
      padding: 0.4em 0;
      min-height: 35px;
      line-height: 35px;
      align-items: center;
    }

    .separator {
      margin: 0 4px;
    }

    .title {
      font-size: 1em;
      padding-top: 2px;
    }

    .desktop-menu {
      display: none;
    }

    .mobile-menu {
      display: initial;
    }

    .mobile-dropdown {
      top: 35px;
    }
  }
</style>
