---
interface Props {
  name: string;
  shortDescription: string;
  techStack: string[];
  homepageUrl: string;
  gitHubUrl: string;
  lastCommitDate?: string;
  index?: number;
}

const { name, shortDescription, techStack, homepageUrl, gitHubUrl, lastCommitDate, index = 0 } = Astro.props;
const jerseyNumber = String(index + 1).padStart(2, '0');
---

<div class="card" style={`--card-index: ${index}`}>
  <span class="jersey-number">{jerseyNumber}</span>
  <span class="postmark">PROJECT</span>
  <a href={homepageUrl}>
    <h2 class="name">{name}</h2>
  </a>
  <p class="short-description">{shortDescription}</p>
  <p class="detail">{techStack.join(', ')}</p>
  <div class="links">
    <a class="link" href={homepageUrl}>homepage</a>
    <a class="link" href={gitHubUrl}>code</a>
  </div>
</div>

<style>
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
    padding: 1rem;
    margin: 0.5rem;
    transition: top ease 1s;
    border-radius: 3px;
    background-color: var(--color-bg-surface);
    box-shadow: var(--shadow-button);
  }

  .card:hover {
    top: -1px;
  }

  @media all and (min-width: 400px) {
    .card {
      width: 75%;
    }
  }

  @media all and (min-width: 500px) {
    .card {
      width: 45%;
    }
  }

  .name {
    color: var(--color-primary);
  }

  .name:hover {
    color: var(--color-primary-hover);
  }

  .short-description {
    margin: 0.35rem 0;
    font-size: 0.9rem;
    height: 2rem;
  }

  .detail {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    margin: 0.25rem 0;
  }

  .links {
    display: flex;
    justify-content: space-around;
    margin-top: auto;
  }

  .link {
    margin: 0 0.5rem;
  }

  /* Hidden by default — shown per theme */
  .jersey-number,
  .postmark {
    display: none;
  }

  /* ===== Sharks theme: hockey trading card ===== */
  :global([data-theme="sharks"]) .card {
    border: 2px solid #EA7200 !important;
    border-radius: 8px;
    background: linear-gradient(170deg, #005a62 0%, #004048 100%) !important;
    padding: 1.25rem 1rem 1rem;
    position: relative;
    overflow: hidden;
    animation: card-slide-in 0.4s ease-out both;
    animation-delay: calc(var(--card-index) * 0.08s);
  }

  @keyframes card-slide-in {
    from {
      opacity: 0;
      transform: translateX(calc(var(--card-index) % 2 == 0 ? -30px : 30px));
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  :global([data-theme="sharks"]) .card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(to right, #EA7200, #006D75, #EA7200);
  }

  :global([data-theme="sharks"]) .jersey-number {
    display: block;
    position: absolute;
    top: 8px;
    right: 10px;
    font-size: 1.8rem;
    font-weight: 900;
    color: rgba(234, 114, 0, 0.15);
    line-height: 1;
    font-family: 'Lato', sans-serif;
  }

  :global([data-theme="sharks"]) .name {
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-size: 1.15em;
  }

  :global([data-theme="sharks"]) .detail {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 4px;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  :global([data-theme="sharks"]) .links {
    border-top: 1px solid rgba(234, 114, 0, 0.25);
    padding-top: 0.5rem;
    margin-top: 0.75rem;
  }

  /* ===== Canada theme: postcard style ===== */
  :global([data-theme="canada"]) .card {
    border: 2px solid rgba(255,255,255,0.4) !important;
    border-radius: 2px;
    background: rgba(255,255,255,0.12) !important;
    position: relative;
    padding: 1.25rem 1rem 1rem;
    animation: card-fall-in 0.5s ease-out both;
    animation-delay: calc(var(--card-index) * 0.1s);
  }

  @keyframes card-fall-in {
    from {
      opacity: 0;
      transform: translateY(-20px) rotate(calc(var(--card-index) * 1deg - 2deg));
    }
    to {
      opacity: 1;
      transform: translateY(0) rotate(0deg);
    }
  }

  :global([data-theme="canada"]) .card::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 4px;
    background: repeating-linear-gradient(
      to bottom,
      transparent,
      transparent 3px,
      rgba(255,255,255,0.2) 3px,
      rgba(255,255,255,0.2) 6px
    );
  }

  :global([data-theme="canada"]) .postmark {
    display: block;
    position: absolute;
    top: 6px;
    right: 8px;
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.25);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 50%;
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: rotate(-15deg);
  }

  :global([data-theme="canada"]) .detail {
    font-style: italic;
  }

  :global([data-theme="canada"]) .detail::before {
    content: 'Ingredients: ';
    font-style: normal;
    font-weight: bold;
    font-size: 0.75rem;
  }

  :global([data-theme="canada"]) .links {
    border-top: 1px dashed rgba(255,255,255,0.3);
    padding-top: 0.5rem;
    margin-top: 0.75rem;
  }
</style>
