---
interface Props {
  name: string;
  shortDescription: string;
  techStack: string[];
  homepageUrl: string;
  gitHubUrl: string;
  lastCommitDate?: string;
}

const { name, shortDescription, techStack, homepageUrl, gitHubUrl, lastCommitDate } = Astro.props;
---

<div class="card">
  <a href={homepageUrl}>
    <h2 class="name">{name}</h2>
  </a>
  <p class="short-description">{shortDescription}</p>
  <p class="detail">{techStack.join(', ')}</p>
  <div class="links">
    <a class="link" href={homepageUrl}>homepage</a>
    <a class="link" href={gitHubUrl}>code</a>
  </div>
</div>

<style>
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
    padding: 1rem;
    margin: 0.5rem;
    transition: top ease 1s;
    border-radius: 3px;
    background-color: var(--color-bg-surface);
    box-shadow: var(--shadow-button);
  }

  .card:hover {
    top: -1px;
  }

  @media all and (min-width: 400px) {
    .card {
      width: 75%;
    }
  }

  @media all and (min-width: 500px) {
    .card {
      width: 45%;
    }
  }

  .name {
    color: var(--color-primary);
  }

  .name:hover {
    color: var(--color-primary-hover);
  }

  .short-description {
    margin: 0.35rem 0;
    font-size: 0.9rem;
    height: 2rem;
  }

  .detail {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    margin: 0.25rem 0;
  }

  .links {
    display: flex;
    justify-content: space-around;
    margin-top: auto;
  }

  .link {
    margin: 0 0.5rem;
  }
</style>
