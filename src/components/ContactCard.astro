---
import AnchorButton from './AnchorButton.astro';

interface Props {
  contact: { email: string; displayedEmail: string; resumeUrl: string };
  social: { github: string; linkedin: string; letterboxd: string; spotify: string };
}

const { contact, social } = Astro.props;
---

<div class="container">
  <div class="social">
    <a
      href={`https://github.com/${social.github}`}
      title={`${social.github} on GitHub`}
      aria-label="GitHub profile"
      target="_blank"
      rel="noopener noreferrer"
    >
      <svg class="icon" viewBox="0 0 496 512" width="20" height="20"
        ><path
          fill="currentColor"
          d="M165.9 397.4c0 2-2.3 3.6-5.2 3.6-3.3.3-5.6-1.3-5.6-3.6 0-2 2.3-3.6 5.2-3.6 3-.3 5.6 1.3 5.6 3.6zm-31.1-4.5c-.7 2 1.3 4.3 4.3 4.9 2.6 1 5.6 0 6.2-2s-1.3-4.3-4.3-5.2c-2.6-.7-5.5.3-6.2 2.3zm44.2-1.7c-2.9.7-4.9 2.6-4.6 4.9.3 2 2.9 3.3 5.9 2.6 2.9-.7 4.9-2.6 4.6-4.6-.3-1.9-3-3.2-5.9-2.9zM244.8 8C106.1 8 0 113.3 0 252c0 110.9 69.8 205.8 169.5 239.2 12.8 2.3 17.3-5.6 17.3-12.1 0-6.2-.3-40.4-.3-61.4 0 0-70 15-84.7-29.8 0 0-11.4-29.1-27.8-36.6 0 0-22.9-15.7 1.6-15.4 0 0 24.9 2 38.6 25.8 21.9 38.6 58.6 27.5 72.9 20.9 2.3-16 8.8-27.1 16-33.7-55.9-6.2-112.3-14.3-112.3-110.5 0-27.5 7.6-41.3 23.6-58.9-2.6-6.5-11.1-33.3 2.6-67.9 20.9-6.5 69 27 69 27 20-5.6 41.5-8.5 62.8-8.5s42.8 2.9 62.8 8.5c0 0 48.1-33.6 69-27 13.7 34.7 5.2 61.4 2.6 67.9 16 17.7 25.8 31.5 25.8 58.9 0 96.5-58.9 104.2-114.8 110.5 9.2 7.9 17 22.9 17 46.4 0 33.7-.3 75.4-.3 83.6 0 6.5 4.6 14.4 17.3 12.1C428.2 457.8 496 362.9 496 252 496 113.3 383.5 8 244.8 8z"
        ></path></svg
      >
    </a>
    <a
      href={`https://linkedin.com/in/${social.linkedin}`}
      title={`${social.linkedin} on LinkedIn`}
      aria-label="LinkedIn profile"
      target="_blank"
      rel="noopener noreferrer"
    >
      <svg class="icon" viewBox="0 0 448 512" width="20" height="20"
        ><path
          fill="currentColor"
          d="M416 32H31.9C14.3 32 0 46.5 0 64.3v383.4C0 465.5 14.3 480 31.9 480H416c17.6 0 32-14.5 32-32.3V64.3c0-17.8-14.4-32.3-32-32.3zM135.4 416H69V202.2h66.5V416zm-33.2-243c-21.3 0-38.5-17.3-38.5-38.5S80.9 96 102.2 96c21.2 0 38.5 17.3 38.5 38.5 0 21.3-17.2 38.5-38.5 38.5zm282.1 243h-66.4V312c0-24.8-.5-56.7-34.5-56.7-34.6 0-39.9 27-39.9 54.9V416h-66.4V202.2h63.7v29.2h.9c8.9-16.8 30.6-34.5 62.9-34.5 67.2 0 79.7 44.3 79.7 101.9V416z"
        ></path></svg
      >
    </a>
    <a
      href={social.letterboxd}
      title="Letterboxd profile"
      aria-label="Letterboxd profile"
      target="_blank"
      rel="noopener noreferrer"
    >
      <svg class="icon" viewBox="0 0 500 500" width="20" height="20"
        ><defs
          ><rect id="lb-mask-1" x="0" y="0" width="129.85" height="141.44"></rect><rect
            id="lb-mask-3"
            x="0"
            y="0"
            width="129.85"
            height="141.44"></rect></defs
        ><g stroke="none" stroke-width="1" fill="none" fill-rule="evenodd"
          ><circle fill="currentColor" cx="250" cy="250" r="250"></circle><g
            transform="translate(61, 180)"
            ><ellipse fill="var(--color-bg)" cx="189" cy="70" rx="70.08" ry="70"></ellipse><g
              transform="translate(248.15, 0)"
              ><mask id="lb-mask-2" fill="white"><use href="#lb-mask-1"></use></mask><ellipse
                fill="var(--color-bg)"
                mask="url(#lb-mask-2)"
                cx="59.77"
                cy="70"
                rx="70.08"
                ry="70"></ellipse></g
            ><g
              ><mask id="lb-mask-4" fill="white"><use href="#lb-mask-3"></use></mask><ellipse
                fill="var(--color-bg)"
                mask="url(#lb-mask-4)"
                cx="70.08"
                cy="70"
                rx="70.08"
                ry="70"></ellipse></g
            ><path
              d="M129.54,107.06 C122.81,96.31 118.92,83.61 118.92,70 C118.92,56.39 122.81,43.69 129.54,32.94 C136.27,43.69 140.16,56.39 140.16,70 C140.16,83.61 136.27,96.31 129.54,107.06Z"
              fill="currentColor"></path><path
              d="M248.46,32.94 C255.19,43.69 259.08,56.39 259.08,70 C259.08,83.61 255.19,96.31 248.46,107.06 C241.73,96.31 237.84,83.61 237.84,70 C237.84,56.39 241.73,43.69 248.46,32.94Z"
              fill="currentColor"></path></g
          ></g
        ></svg
      >
    </a>
    <a
      href={social.spotify}
      title="Spotify profile"
      aria-label="Spotify profile"
      target="_blank"
      rel="noopener noreferrer"
    >
      <svg class="icon" viewBox="0 0 496 512" width="20" height="20"
        ><path
          fill="currentColor"
          d="M248 8C111.1 8 0 119.1 0 256s111.1 248 248 248 248-111.1 248-248S384.9 8 248 8zm100.7 364.9c-4.2 0-6.8-1.3-10.7-3.6-62.4-37.6-135-39.2-206.7-24.5-3.9 1-9 2.6-11.9 2.6-9.7 0-15.8-7.7-15.8-15.8 0-10.3 6.1-15.2 13.6-16.8 81.9-18.1 165.6-16.5 237 26.2 6.1 3.9 9.7 7.4 9.7 16.5s-7.1 15.4-15.2 15.4zm26.9-65.6c-5.2 0-8.7-2.3-12.3-4.2-62.5-37-155.7-51.9-238.6-29.4-4.8 1.3-7.4 2.6-11.9 2.6-10.7 0-19.4-8.7-19.4-19.4s5.2-17.8 15.5-20.7c27.8-7.8 56.2-13.6 97.8-13.6 64.9 0 127.6 16.1 177 45.5 8.1 4.8 11.3 11 11.3 19.7-.1 10.8-8.5 19.5-19.4 19.5zm31-76.2c-5.2 0-8.4-1.3-12.9-3.9-71.2-42.5-198.5-52.7-280.9-29.7-3.6 1-8.1 2.6-12.9 2.6-13.2 0-23.3-10.3-23.3-23.6 0-13.6 8.4-21.3 17.4-23.9 35.2-10.3 74.6-15.2 117.5-15.2 73 0 149.5 15.2 205.4 47.8 7.8 4.5 12.9 10.7 12.9 22.6 0 13.6-11 23.3-23.2 23.3z"
        ></path></svg
      >
    </a>
  </div>
  <div class="email">
    <a href={`mailto:${contact.email}`}>
      <svg class="icon email-icon" viewBox="0 0 512 512" width="16" height="16"
        ><path
          fill="currentColor"
          d="M464 64H48C21.49 64 0 85.49 0 112v288c0 26.51 21.49 48 48 48h416c26.51 0 48-21.49 48-48V112c0-26.51-21.49-48-48-48zm0 48v40.805c-22.422 18.259-58.168 46.651-134.587 106.49-16.841 13.247-50.201 45.072-73.413 44.701-23.208.375-56.579-31.459-73.413-44.701C106.18 199.465 70.425 171.067 48 152.805V112h416zM48 400V214.398c22.914 18.251 55.409 43.862 104.938 82.646 21.857 17.205 60.134 55.186 103.062 54.955 42.717.231 80.509-37.199 103.053-54.947 49.528-38.783 82.032-64.401 104.947-82.653V400H48z"
        ></path></svg
      >
      {contact.displayedEmail}
    </a>
  </div>
  <AnchorButton href={contact.resumeUrl} external text="resume" color="secondary" />
</div>

<style>
  .container {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 34em;
    max-width: 90%;
    margin-left: auto;
    margin-right: auto;
  }

  .icon {
    margin: 0 6px;
  }

  .email-icon {
    vertical-align: text-bottom;
  }

  .social,
  .email {
    color: var(--color-text-muted) !important;
    margin-bottom: 1em;
  }

  .social a,
  .email a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .social a:hover,
  .email a:hover {
    color: var(--color-text-muted-hover);
  }
</style>
