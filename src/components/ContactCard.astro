---
import AnchorButton from './AnchorButton.astro';

interface Props {
  contact: { email: string; displayedEmail: string; resumeUrl: string };
  social: { github: string; linkedin: string };
}

const { contact, social } = Astro.props;
---

<div class="container">
  <div class="social">
    <a href={`https://github.com/${social.github}`} title={`${social.github} on GitHub`} aria-label="GitHub profile" target="_blank" rel="noopener noreferrer">
      <svg class="icon" viewBox="0 0 496 512" width="20" height="20"><path fill="currentColor" d="M165.9 397.4c0 2-2.3 3.6-5.2 3.6-3.3.3-5.6-1.3-5.6-3.6 0-2 2.3-3.6 5.2-3.6 3-.3 5.6 1.3 5.6 3.6zm-31.1-4.5c-.7 2 1.3 4.3 4.3 4.9 2.6 1 5.6 0 6.2-2s-1.3-4.3-4.3-5.2c-2.6-.7-5.5.3-6.2 2.3zm44.2-1.7c-2.9.7-4.9 2.6-4.6 4.9.3 2 2.9 3.3 5.9 2.6 2.9-.7 4.9-2.6 4.6-4.6-.3-1.9-3-3.2-5.9-2.9zM244.8 8C106.1 8 0 113.3 0 252c0 110.9 69.8 205.8 169.5 239.2 12.8 2.3 17.3-5.6 17.3-12.1 0-6.2-.3-40.4-.3-61.4 0 0-70 15-84.7-29.8 0 0-11.4-29.1-27.8-36.6 0 0-22.9-15.7 1.6-15.4 0 0 24.9 2 38.6 25.8 21.9 38.6 58.6 27.5 72.9 20.9 2.3-16 8.8-27.1 16-33.7-55.9-6.2-112.3-14.3-112.3-110.5 0-27.5 7.6-41.3 23.6-58.9-2.6-6.5-11.1-33.3 2.6-67.9 20.9-6.5 69 27 69 27 20-5.6 41.5-8.5 62.8-8.5s42.8 2.9 62.8 8.5c0 0 48.1-33.6 69-27 13.7 34.7 5.2 61.4 2.6 67.9 16 17.7 25.8 31.5 25.8 58.9 0 96.5-58.9 104.2-114.8 110.5 9.2 7.9 17 22.9 17 46.4 0 33.7-.3 75.4-.3 83.6 0 6.5 4.6 14.4 17.3 12.1C428.2 457.8 496 362.9 496 252 496 113.3 383.5 8 244.8 8z"/></svg>
    </a>
    <a href={`https://linkedin.com/in/${social.linkedin}`} title={`${social.linkedin} on LinkedIn`} aria-label="LinkedIn profile" target="_blank" rel="noopener noreferrer">
      <svg class="icon" viewBox="0 0 448 512" width="20" height="20"><path fill="currentColor" d="M416 32H31.9C14.3 32 0 46.5 0 64.3v383.4C0 465.5 14.3 480 31.9 480H416c17.6 0 32-14.5 32-32.3V64.3c0-17.8-14.4-32.3-32-32.3zM135.4 416H69V202.2h66.5V416zm-33.2-243c-21.3 0-38.5-17.3-38.5-38.5S80.9 96 102.2 96c21.2 0 38.5 17.3 38.5 38.5 0 21.3-17.2 38.5-38.5 38.5zm282.1 243h-66.4V312c0-24.8-.5-56.7-34.5-56.7-34.6 0-39.9 27-39.9 54.9V416h-66.4V202.2h63.7v29.2h.9c8.9-16.8 30.6-34.5 62.9-34.5 67.2 0 79.7 44.3 79.7 101.9V416z"/></svg>
    </a>
  </div>
  <div class="email">
    <a href={`mailto:${contact.email}`}>
      <svg class="icon email-icon" viewBox="0 0 512 512" width="16" height="16"><path fill="currentColor" d="M464 64H48C21.49 64 0 85.49 0 112v288c0 26.51 21.49 48 48 48h416c26.51 0 48-21.49 48-48V112c0-26.51-21.49-48-48-48zm0 48v40.805c-22.422 18.259-58.168 46.651-134.587 106.49-16.841 13.247-50.201 45.072-73.413 44.701-23.208.375-56.579-31.459-73.413-44.701C106.18 199.465 70.425 171.067 48 152.805V112h416zM48 400V214.398c22.914 18.251 55.409 43.862 104.938 82.646 21.857 17.205 60.134 55.186 103.062 54.955 42.717.231 80.509-37.199 103.053-54.947 49.528-38.783 82.032-64.401 104.947-82.653V400H48z"/></svg>
      {contact.displayedEmail}
    </a>
  </div>
  <AnchorButton href={contact.resumeUrl} external text="resume" color="secondary" />
</div>

<style>
  .container {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 34em;
    max-width: 90%;
    margin-left: auto;
    margin-right: auto;
  }

  .icon {
    margin: 0 6px;
  }

  .email-icon {
    vertical-align: text-bottom;
  }

  .social, .email {
    color: var(--color-text-muted) !important;
    margin-bottom: 1em;
  }

  .social a, .email a {
    color: var(--color-text-muted);
  }

  .social a:hover, .email a:hover {
    color: var(--color-text-muted-hover);
  }
</style>
