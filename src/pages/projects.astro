---
import PageLayout from '../layouts/PageLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import projectsData from '../data/projects.json';

const projects = projectsData.projects;
---

<PageLayout title="colin tinney - projects" description="Personal projects." headerTitle="projects">
  <div class="banner">
    <p class="banner-text default-banner">
      None of these projects are actively maintained.
      They are preserved here for reference.
    </p>
    <p class="banner-text sharks-banner">
      These players have been sent to the press box.
      No longer on the active roster.
    </p>
    <p class="banner-text canada-banner">
      Sorry, none of these projects are actively maintained, eh.
      They're preserved here for reference.
    </p>
  </div>
  <section class="projects">
    {projects.map((project, i) => (
      <ProjectCard {...project} index={i} />
    ))}
  </section>
</PageLayout>

<style>
  .projects {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    box-sizing: content-box;
    padding: 1rem 0;
  }

  .banner {
    margin: 1rem auto;
    max-width: 600px;
    padding: 0.75rem 1.25rem;
    border: 1px solid var(--color-secondary);
    border-radius: 3px;
    background-color: var(--color-bg);
    text-align: center;
  }

  .banner-text {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-text);
  }

  /* Theme-specific banner text visibility */
  .sharks-banner,
  .canada-banner {
    display: none;
  }

  :global([data-theme="sharks"]) .default-banner { display: none; }
  :global([data-theme="sharks"]) .sharks-banner { display: block; }
  :global([data-theme="canada"]) .default-banner { display: none; }
  :global([data-theme="canada"]) .canada-banner { display: block; }

  /* Sharks: scoreboard-style banner */
  :global([data-theme="sharks"]) .banner {
    border: 2px solid #EA7200 !important;
    background: linear-gradient(180deg, #003d42 0%, #005a62 100%) !important;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.85rem;
  }

  /* Canada: friendly postcard banner */
  :global([data-theme="canada"]) .banner {
    border: 2px solid rgba(255,255,255,0.5) !important;
    background-color: rgba(255,255,255,0.15) !important;
    border-radius: 6px;
  }
</style>
