---
import PageLayout from '../layouts/PageLayout.astro';
import { themes } from '../themes/registry';

const themeEntries = Object.entries(themes);
---

<PageLayout title="404" description="This page is missing." headerTitle="404">
  <div class="container flex-center">
    {
      themeEntries.map(([id, theme]) =>
        theme.pageContent?.notFoundPage ? (
          <div data-404={id} class={id === 'default' ? '' : 'hidden'}>
            <h1>{theme.pageContent.notFoundPage.heading}</h1>
            <p class="truth">{theme.pageContent.notFoundPage.message}</p>
          </div>
        ) : null,
      )
    }
    <a href="/" class="home-link">Go home</a>
    <a href="/secret" class="hidden-link" aria-label="Secret">.</a>
  </div>
</PageLayout>

<style>
  .container {
    padding: var(--space-lg);
    text-align: center;
  }

  .truth {
    margin-top: var(--space-md);
    font-size: var(--text-base);
    color: var(--color-text-secondary);
  }

  .home-link {
    margin-top: var(--space-lg);
    font-size: var(--text-base);
  }

  .hidden-link {
    margin-top: var(--space-lg);
    color: var(--color-bg);
    text-decoration: none;
    font-size: 0.5rem;
    transition: color var(--transition-normal);
  }

  .hidden-link:hover {
    color: var(--color-text-muted);
  }
</style>

<style is:global>
  [data-404].hidden {
    display: none;
  }
</style>
