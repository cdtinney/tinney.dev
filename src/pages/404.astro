---
import PageLayout from '../layouts/PageLayout.astro';
import { themes } from '../themes/index.js';

const themeEntries = Object.entries(themes);
---

<PageLayout title="404" description="This page is missing." headerTitle="404">
  <div class="container">
    {
      themeEntries.map(([id, theme]) =>
        theme.notFound ? (
          <div data-404={id} class={id === 'default' ? '' : 'hidden'}>
            <h1>{theme.notFound.heading}</h1>
            <p class="truth">{theme.notFound.message}</p>
          </div>
        ) : null,
      )
    }
    <a href="/" class="home-link">Go home</a>
  </div>
</PageLayout>

<style>
  .container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    text-align: center;
  }

  .truth {
    margin-top: 1rem;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
  }

  .home-link {
    margin-top: 2rem;
    font-size: 0.9rem;
  }
</style>

<style is:global>
  [data-404].hidden {
    display: none;
  }
</style>
