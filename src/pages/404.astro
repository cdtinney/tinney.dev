---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="404" description="This page is missing." headerTitle="404">
  <div class="container">
    <p class="route" id="route-display"></p>

    <div data-404-default>
      <h1>This content is not available in your country.</h1>
      <p class="truth">Just kidding. This page does not exist.</p>
    </div>

    <div data-404-sharks>
      <h1>Offside!</h1>
      <p class="truth">This page has been sent to the penalty box.</p>
    </div>

    <div data-404-canada>
      <h1>Sorry, this page doesn't exist.</h1>
      <p class="truth">We looked everywhere. Double-double sorry.</p>
    </div>

    <div data-404-underwater>
      <h1>Lost at sea.</h1>
      <p class="truth">This page sank beyond our maximum dive depth.</p>
    </div>

    <a href="/" class="home-link">Go home</a>
  </div>
</PageLayout>

<script>
  const el = document.getElementById('route-display');
  if (el) {
    el.textContent = window.location.pathname.replace('/', '');
  }
</script>

<style>
  .container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    text-align: center;
  }

  .route {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .truth {
    margin-top: 1rem;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
  }

  .home-link {
    margin-top: 2rem;
    font-size: 0.9rem;
  }
</style>

<style is:global>
  [data-404-sharks],
  [data-404-canada],
  [data-404-underwater] {
    display: none;
  }
</style>
