---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection, render } from 'astro:content';
import { formatDate } from '../../utils/formatDate.js';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog', ({ data }) => !data.archived && !data.draft);
  const sorted = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  return sorted.map((post, index) => ({
    params: { slug: post.data.path.replace('/blog/', '') },
    props: {
      post,
      prevPost: index > 0 ? sorted[index - 1] : null,
      nextPost: index < sorted.length - 1 ? sorted[index + 1] : null,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);
---

<BlogLayout title={post.data.title} description={post.data.excerpt} ogType="article">
  <article>
    <header>
      <h1 class="title">{post.data.title}</h1>
      <p class="date">{formatDate(post.data.date)}</p>
    </header>
    <div class="content">
      <Content />
    </div>
  </article>
  <footer class="footer">
    {
      prevPost && (
        <a href={prevPost.data.path} class="footer-link">
          {`\u2190 ${prevPost.data.title}`}
        </a>
      )
    }
    {
      nextPost && (
        <a href={nextPost.data.path} class="footer-link">
          {`${nextPost.data.title} \u2192`}
        </a>
      )
    }
  </footer>
</BlogLayout>

<style>
  .title {
    margin-bottom: 0;
  }

  .date {
    font-size: 0.75rem;
  }

  .content {
    font-family: 'Open Sans', sans-serif;
    font-size: 0.95em;
  }

  .content :global(h3) {
    margin-top: 0.75rem;
    font-weight: 600;
  }

  .content :global(a) {
    text-decoration: underline;
  }

  .content :global(li > p) {
    margin: 0;
  }

  .content :global(code) {
    padding: 0;
    font-size: 0.8rem;
    white-space: pre-wrap !important;
    word-wrap: break-word !important;
  }

  .content :global(blockquote) {
    margin-left: 0.5em;
  }

  .footer {
    display: flex;
    justify-content: space-evenly;
    border-top: 1px solid rgba(15, 15, 15, 0.4);
    margin-top: 1.5em;
    padding: 1em 0.25em;
  }

  .footer-link {
    max-width: 50%;
    text-align: center;
  }
</style>
