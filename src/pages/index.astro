---
import DefaultLayout from '../layouts/DefaultLayout.astro';
import Brand from '../components/Brand.astro';
import ContactCard from '../components/ContactCard.astro';
import PageLinks from '../components/PageLinks.astro';
import { site } from '../data/site';

const pageLinks = [
  { to: '/blog', name: 'blog' },
  { to: '/projects', name: 'projects' },
];
---

<DefaultLayout>
  <div class="container">
    <header>
      <Brand large title={site.title} />
      <p>Hi! I'm a full-stack software engineer passionate about clean code and positive user experiences.
      Currently working at <a href="https://squareup.com">Block (formerly known as Square)</a>.</p>
      <PageLinks links={pageLinks} />
    </header>
    <main class="contact-card">
      <ContactCard contact={site.contact} social={site.social} />
    </main>
  </div>
</DefaultLayout>

<style>
  .container {
    width: 34em;
    max-width: 90%;
    margin-left: auto;
    margin-right: auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    height: 100%;
    justify-content: center;
  }

  .contact-card {
    padding-top: 1rem;
    border-top: 1px solid rgba(15, 15, 15, 0.4);
  }
</style>
