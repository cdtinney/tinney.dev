---
import DefaultLayout from '../layouts/DefaultLayout.astro';
import MediaCard from '../components/faves/MediaCard.astro';
import { site } from '../data/site';
import { moviesByGenre, featuredLists } from '../data/faves/movies';
import { miniSeries, fullSeries } from '../data/faves/tv';
import music from '../data/faves/music';

const byYearDesc = <T extends { year: number }>(items: T[]) =>
  items.toSorted((a, b) => b.year - a.year);

const sortedFullSeries = byYearDesc(fullSeries);
const sortedMiniSeries = byYearDesc(miniSeries);
const sortedMusic = byYearDesc(music);
const sortedMoviesByGenre = moviesByGenre.map((g) => ({ ...g, movies: byYearDesc(g.movies) }));
---

<DefaultLayout title={`${site.title} - faves`} description="A few of my favourite things.">
  <script is:inline>
    // Prevent white flash for dark mode users
    (function () {
      const s = localStorage.getItem('faves-dark');
      const prefersDark = globalThis.matchMedia('(prefers-color-scheme: dark)').matches;
      if (s === 'dark' || (s === null && prefersDark)) {
        document.documentElement.style.setProperty('--color-bg', '#18181b');
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
  <div class="faves">
    <nav class="toolbar" id="toolbar">
      <div class="toolbar-tabs">
        <a href="#movies" class="tab-link link-quiet active" data-tab>Movies</a>
        <a href="#tv-series" class="tab-link link-quiet" data-tab>TV</a>
        <a href="#tv-mini" class="tab-link link-quiet" data-tab>Mini Series</a>
        <a href="#music" class="tab-link link-quiet" data-tab>Albums</a>
      </div>
      <div class="toolbar-controls">
        <div class="view-dropdown" id="view-dropdown">
          <button class="view-toggle" id="view-toggle" aria-expanded="false" aria-haspopup="true">
            <svg
              class="view-icon"
              viewBox="0 0 16 16"
              width="14"
              height="14"
              fill="currentColor"
              aria-hidden="true"
            >
              <rect x="1" y="1" width="6" height="6" rx="1"></rect>
              <rect x="9" y="1" width="6" height="6" rx="1"></rect>
              <rect x="1" y="9" width="6" height="6" rx="1"></rect>
              <rect x="9" y="9" width="6" height="6" rx="1"></rect>
            </svg>
            <span class="view-label">Full</span>
            <svg
              class="view-chevron"
              viewBox="0 0 10 6"
              width="8"
              height="5"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              aria-hidden="true"
            >
              <polyline points="1,1 5,5 9,1"></polyline>
            </svg>
          </button>
          <div class="view-menu" id="view-menu" role="menu">
            <button class="view-option btn-reset active" data-view="full" role="menuitem">
              <svg viewBox="0 0 16 16" width="12" height="12" fill="currentColor"
                ><rect x="1" y="1" width="6" height="6" rx="1"></rect><rect
                  x="9"
                  y="1"
                  width="6"
                  height="6"
                  rx="1"></rect><rect x="1" y="9" width="6" height="6" rx="1"></rect><rect
                  x="9"
                  y="9"
                  width="6"
                  height="6"
                  rx="1"></rect></svg
              >
              Full
            </button>
            <button class="view-option btn-reset" data-view="covers" role="menuitem">
              <svg viewBox="0 0 16 16" width="12" height="12" fill="currentColor"
                ><rect x="1" y="1" width="4" height="6" rx="1"></rect><rect
                  x="6"
                  y="1"
                  width="4"
                  height="6"
                  rx="1"></rect><rect x="11" y="1" width="4" height="6" rx="1"></rect><rect
                  x="1"
                  y="9"
                  width="4"
                  height="6"
                  rx="1"></rect><rect x="6" y="9" width="4" height="6" rx="1"></rect><rect
                  x="11"
                  y="9"
                  width="4"
                  height="6"
                  rx="1"></rect></svg
              >
              Covers
            </button>
            <button class="view-option btn-reset" data-view="compact" role="menuitem">
              <svg viewBox="0 0 16 16" width="12" height="12" fill="currentColor"
                ><rect x="1" y="2" width="14" height="2" rx="1"></rect><rect
                  x="1"
                  y="7"
                  width="14"
                  height="2"
                  rx="1"></rect><rect x="1" y="12" width="14" height="2" rx="1"></rect></svg
              >
              List
            </button>
          </div>
        </div>
        <span class="ctrl-sep"></span>
        <button class="ctrl-btn active" data-sort="year" data-sort-dir="desc" title="Sort by year"
          >Year <span class="sort-arrow" aria-hidden="true"></span></button
        >
      </div>
    </nav>

    <!-- Movies -->
    <section id="movies" class="section">
      <div class="section-header">
        <h2 class="section-title">Movies</h2>
        <button class="random-btn" id="random-movie">Random</button>
      </div>
      <p class="featured-lists">
        <span class="featured-label">Featured lists</span>
        {
          featuredLists.map((list, i) => (
            <>
              {i > 0 && <span class="featured-sep">·</span>}
              <a
                href={list.url}
                class:list={['featured-link link-quiet', { 'featured-bold': list.bold }]}
                target="_blank"
                rel="noopener noreferrer"
              >
                {list.name}
              </a>
            </>
          ))
        }
      </p>
      {
        sortedMoviesByGenre.map((group) => (
          <div class="genre-group">
            <div class="genre-header">
              <h3 class="genre-title">{group.genre}</h3>
              {group.lists && (
                <span class="genre-links">
                  {group.lists.map((list) => (
                    <a
                      href={list.url}
                      class="genre-link link-quiet"
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      {list.name}
                    </a>
                  ))}
                </span>
              )}
            </div>
            <div class="poster-row" data-sortable>
              {group.movies.map((movie) => (
                <MediaCard
                  name={movie.name}
                  year={movie.year}
                  cover={movie.cover}
                  subtitle={`${movie.year} · ${movie.director}`}
                  extra={movie.favouriteCast?.join(', ')}
                  href={movie.letterboxd}
                />
              ))}
            </div>
          </div>
        ))
      }
    </section>

    <!-- TV: Series -->
    <section id="tv-series" class="section">
      <h2 class="section-title">TV — Series</h2>
      <div class="poster-grid" data-sortable>
        {
          sortedFullSeries.map((show) => (
            <MediaCard
              name={show.name}
              year={show.year}
              cover={show.cover}
              subtitle={`${show.year} · ${show.creator}`}
              extra={show.favouriteCast?.join(', ')}
            />
          ))
        }
      </div>
    </section>

    <!-- TV: Mini Series -->
    <section id="tv-mini" class="section">
      <h2 class="section-title">TV — Mini Series</h2>
      <div class="poster-grid" data-sortable>
        {
          sortedMiniSeries.map((show) => (
            <MediaCard
              name={show.name}
              year={show.year}
              cover={show.cover}
              subtitle={`${show.year} · ${show.creator}`}
              extra={show.favouriteCast?.join(', ')}
            />
          ))
        }
      </div>
    </section>

    <!-- Music -->
    <section id="music" class="section">
      <h2 class="section-title">Music — Albums</h2>
      <div class="album-grid" data-sortable>
        {
          sortedMusic.map((album) => (
            <MediaCard
              name={album.name}
              year={album.year}
              cover={album.cover}
              subtitle={`${album.artist} · ${album.year}`}
              extra={album.genres.join(', ')}
              href={album.spotify}
              aspectRatio="1 / 1"
            />
          ))
        }
      </div>
    </section>
    <button class="dark-toggle icon-btn" id="dark-toggle" aria-label="Toggle dark mode">
      <svg
        class="dark-icon sun"
        viewBox="0 0 24 24"
        width="16"
        height="16"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
      >
        <circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line
          x1="12"
          y1="21"
          x2="12"
          y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line
          x1="18.36"
          y1="18.36"
          x2="19.78"
          y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line
          x1="21"
          y1="12"
          x2="23"
          y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line
          x1="18.36"
          y1="5.64"
          x2="19.78"
          y2="4.22"></line>
      </svg>
      <svg
        class="dark-icon moon"
        viewBox="0 0 24 24"
        width="16"
        height="16"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
      >
        <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"></path>
      </svg>
    </button>
  </div>
</DefaultLayout>

<style>
  /* Dark mode toggle */
  .dark-toggle {
    position: fixed;
    bottom: 1.25rem;
    right: 1.25rem;
    z-index: 20;
    color: var(--color-text-muted);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: all var(--transition-fast);
  }

  .dark-toggle:hover {
    color: var(--color-text);
    border-color: var(--color-text-secondary);
  }

  .dark-icon.moon {
    display: none;
  }

  :global(.dark) .dark-icon.sun {
    display: none;
  }
  :global(.dark) .dark-icon.moon {
    display: block;
  }

  .faves {
    width: 100%;
    max-width: 56rem;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }

  /* Toolbar */
  .toolbar {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.6rem 0;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .toolbar-tabs {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .tab-link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-muted);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-sm);
  }

  .tab-link:hover {
    color: var(--color-text);
    background: var(--color-border);
  }

  .tab-link.active {
    color: var(--color-primary);
    background: none;
  }

  .toolbar-controls {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-shrink: 0;
  }

  /* View dropdown */
  .view-dropdown {
    position: relative;
  }

  .view-toggle {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    background: none;
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    padding: 0.2rem 0.45rem;
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: 500;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .view-toggle:hover {
    color: var(--color-text);
    border-color: var(--color-text-secondary);
  }

  .view-icon {
    flex-shrink: 0;
  }

  .view-label {
    line-height: 1;
  }

  .view-chevron {
    flex-shrink: 0;
    opacity: 0.6;
    transition: transform var(--transition-fast);
  }

  :global(.view-dropdown.open) .view-chevron {
    transform: rotate(180deg);
  }

  .view-menu {
    display: none;
    position: absolute;
    top: calc(100% + 4px);
    right: 0;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 0.2rem;
    min-width: 100px;
    box-shadow: var(--shadow-dropdown);
    z-index: 20;
  }

  :global(.view-dropdown.open) .view-menu {
    display: flex;
    flex-direction: column;
  }

  .view-option {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    color: var(--color-text-muted);
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    text-align: left;
    transition: all var(--transition-fast);
    width: 100%;
  }

  .view-option:hover {
    background: var(--color-border);
    color: var(--color-text);
  }

  .view-option.active {
    color: var(--color-primary);
  }

  .ctrl-btn {
    background: none;
    border: 1px solid transparent;
    color: var(--color-text-muted);
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: 500;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .ctrl-btn:hover {
    color: var(--color-text);
  }

  .ctrl-btn.active {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .sort-arrow::after {
    content: '\2195';
  }

  :global(.ctrl-btn.active[data-sort-dir='asc']) .sort-arrow::after {
    content: '\2191';
  }

  :global(.ctrl-btn.active[data-sort-dir='desc']) .sort-arrow::after {
    content: '\2193';
  }

  .ctrl-sep {
    width: 1px;
    height: 0.8rem;
    background: var(--color-border);
    margin: 0 0.25rem;
  }

  /* Sections */
  .section {
    margin-bottom: var(--space-lg);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    margin-bottom: 0.2rem;
  }

  .section-title {
    font-size: var(--text-md);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 0.75rem;
  }

  .random-btn {
    background: var(--color-primary);
    color: var(--color-bg);
    border: none;
    padding: 0.2rem 0.55rem;
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: 600;
    cursor: pointer;
    letter-spacing: 0.03em;
    transition:
      background var(--transition-fast),
      transform var(--transition-fast);
  }

  .random-btn:hover {
    background: var(--color-primary-hover);
    transform: translateY(-1px);
  }

  .random-btn:active {
    transform: translateY(0);
  }

  /* Featured lists */
  .featured-lists {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin: 0 0 1.25rem;
    line-height: 1.6;
  }

  .featured-label {
    color: var(--color-text-muted);
  }

  .featured-label::after {
    content: ':';
    margin-right: 0.35rem;
  }

  .featured-sep {
    margin: 0 0.3rem;
    color: var(--color-border);
  }

  .featured-link {
    color: var(--color-text-secondary);
  }

  .featured-link:hover {
    color: var(--color-primary);
  }

  .featured-bold {
    font-weight: 600;
  }

  /* Genre groups (movies) */
  .genre-group {
    margin-bottom: 1.75rem;
  }

  .genre-header {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .genre-title {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0;
  }

  .genre-links {
    display: flex;
    gap: 0.4rem;
  }

  .genre-link {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }

  .genre-link:hover {
    color: var(--color-primary);
  }

  .genre-link::before {
    content: '→ ';
  }

  /* 4-up poster row for movies */
  .poster-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
  }

  /* Auto-fill grid for TV */
  .poster-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
    gap: 0.75rem;
  }

  /* Music grid */
  .album-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: var(--space-md);
  }

  /* ===== View: covers only ===== */
  :global(.view-covers) .media-info {
    display: none;
  }

  :global(.view-covers) .poster-grid,
  :global(.view-covers) .album-grid {
    grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
    gap: var(--space-xs);
  }

  :global(.view-covers) .poster-row {
    gap: var(--space-xs);
  }

  /* ===== View: compact list ===== */
  :global(.view-compact) .poster-row,
  :global(.view-compact) .poster-grid,
  :global(.view-compact) .album-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  :global(.view-compact) .media-card {
    flex-direction: row;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-xs) 0;
    border-bottom: 1px solid var(--color-border);
  }

  :global(.view-compact) .media-img {
    width: 36px;
    aspect-ratio: auto;
    flex-shrink: 0;
    border-radius: 2px;
  }

  :global(.view-compact) .media-info {
    padding-top: 0;
  }

  :global(.view-compact) .media-extra {
    display: none;
  }

  :global(.view-compact) .media-name {
    font-size: var(--text-base);
  }

  /* ===== Responsive ===== */
  @media (max-width: 640px) {
    .faves {
      padding: 1.25rem 1rem 3rem;
    }

    .poster-row {
      grid-template-columns: repeat(2, 1fr);
    }

    .poster-grid {
      grid-template-columns: repeat(auto-fill, minmax(90px, 1fr));
    }

    .album-grid {
      grid-template-columns: repeat(auto-fill, minmax(90px, 1fr));
    }

    .toolbar {
      flex-wrap: wrap;
    }

    .toolbar-tabs {
      flex-wrap: wrap;
    }
  }
</style>

<script>
  const faves = document.querySelector('.faves') as HTMLElement;

  // View dropdown
  const dropdown = document.querySelector('#view-dropdown')!;
  const toggle = document.querySelector('#view-toggle')!;
  const label = toggle.querySelector('.view-label')!;

  toggle.addEventListener('click', () => {
    const open = dropdown.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(open));
  });

  document.addEventListener('click', (e) => {
    if (!dropdown.contains(e.target as Node)) {
      dropdown.classList.remove('open');
      toggle.setAttribute('aria-expanded', 'false');
    }
  });

  for (const btn of document.querySelectorAll<HTMLButtonElement>('.view-option')) {
    btn.addEventListener('click', () => {
      for (const b of document.querySelectorAll('.view-option')) b.classList.remove('active');
      btn.classList.add('active');
      label.textContent = btn.textContent?.trim() || 'Full';
      faves.classList.remove('view-covers', 'view-compact');
      if (btn.dataset.view === 'covers') faves.classList.add('view-covers');
      if (btn.dataset.view === 'compact') faves.classList.add('view-compact');
      dropdown.classList.remove('open');
      toggle.setAttribute('aria-expanded', 'false');
    });
  }

  // Sort
  for (const grid of document.querySelectorAll<HTMLElement>('[data-sortable]')) {
    for (const [i, child] of [...grid.children].entries()) {
      (child as HTMLElement).dataset.originalIndex = String(i);
    }
  }

  function sortAllByYear(ascending: boolean) {
    for (const grid of document.querySelectorAll<HTMLElement>('[data-sortable]')) {
      const items = [...grid.children] as HTMLElement[];
      items.sort((a, b) => {
        const diff = Number(a.dataset.year || 0) - Number(b.dataset.year || 0);
        return ascending ? diff : -diff;
      });
      for (const item of items) grid.append(item);
    }
  }

  // Sort: desc → asc → default (off)
  const yearBtn = document.querySelector<HTMLButtonElement>('[data-sort="year"]');
  yearBtn?.addEventListener('click', () => {
    const dir = yearBtn.dataset.sortDir;
    let nextDir: string;

    if (!yearBtn.classList.contains('active')) {
      nextDir = 'desc';
      yearBtn.classList.add('active');
    } else if (dir === 'desc') {
      nextDir = 'asc';
    } else {
      // Reset to default order
      nextDir = 'desc';
      yearBtn.classList.remove('active');
      yearBtn.dataset.sortDir = nextDir;

      for (const grid of document.querySelectorAll<HTMLElement>('[data-sortable]')) {
        const items = [...grid.children] as HTMLElement[];
        items.sort(
          (a, b) => Number(a.dataset.originalIndex || 0) - Number(b.dataset.originalIndex || 0),
        );
        for (const item of items) grid.append(item);
      }
      return;
    }

    yearBtn.dataset.sortDir = nextDir;
    sortAllByYear(nextDir === 'asc');
  });

  // Random movie
  document.querySelector('#random-movie')?.addEventListener('click', () => {
    const allCards = document.querySelectorAll<HTMLElement>('#movies .media-card');
    if (allCards.length === 0) return;

    // Clear previous highlight
    for (const c of allCards) c.classList.remove('highlight');

    const pick = allCards[Math.floor(Math.random() * allCards.length)];
    pick.classList.add('highlight');
    pick.scrollIntoView({ behavior: 'smooth', block: 'center' });
  });

  // Active tab tracking on scroll
  const tabs = document.querySelectorAll<HTMLAnchorElement>('[data-tab]');
  const sections = [...tabs].map((tab) => {
    const id = tab.getAttribute('href')?.slice(1);
    return id ? document.querySelector(`#${id}`) : null;
  });

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          for (const t of tabs) t.classList.remove('active');
          const match = [...tabs].find((t) => t.getAttribute('href') === `#${entry.target.id}`);
          match?.classList.add('active');
        }
      }
    },
    { rootMargin: '-20% 0px -60% 0px' },
  );

  for (const s of sections) {
    if (s) observer.observe(s);
  }

  // Remove shimmer when images load
  for (const img of document.querySelectorAll<HTMLImageElement>('.media-img')) {
    if (img.complete) {
      img.dataset.loaded = '';
    } else {
      img.addEventListener(
        'load',
        () => {
          img.dataset.loaded = '';
        },
        { once: true },
      );
    }
  }

  // Dark mode — applies via inline styles to override theme system
  const root = document.documentElement;
  const darkBtn = document.querySelector('#dark-toggle')!;

  const DARK_COLORS: Record<string, string> = {
    '--color-text': '#e4e4e7',
    '--color-text-secondary': '#a1a1aa',
    '--color-text-muted': '#71717a',
    '--color-text-muted-hover': '#a1a1aa',
    '--color-bg': '#18181b',
    '--color-bg-surface': '#27272a',
    '--color-primary': '#60a5fa',
    '--color-primary-hover': '#93c5fd',
    '--color-secondary': '#f472b6',
    '--color-secondary-hover': '#f9a8d4',
    '--color-border': 'rgba(255, 255, 255, 0.1)',
    '--color-code-bg': '#1e1e22',
    '--color-code-text': '#a1a1aa',
    '--shadow-button': '0 2px 6px rgba(0, 0, 0, 0.4)',
  };

  import { applyTheme, getStoredThemeId } from '../themes/registry';

  function applyDark() {
    for (const [key, val] of Object.entries(DARK_COLORS)) {
      root.style.setProperty(key, val);
    }
    root.classList.add('dark');
  }

  function removeDark() {
    root.classList.remove('dark');
    applyTheme(getStoredThemeId() || 'default');
  }

  // Apply dark after theme system has initialized
  const storedDark = localStorage.getItem('faves-dark');
  const prefersDark = globalThis.matchMedia('(prefers-color-scheme: dark)').matches;
  if (storedDark === 'dark' || (storedDark === null && prefersDark)) {
    applyDark();
  }

  darkBtn.addEventListener('click', () => {
    if (root.classList.contains('dark')) {
      removeDark();
      localStorage.setItem('faves-dark', 'light');
    } else {
      applyDark();
      localStorage.setItem('faves-dark', 'dark');
    }
  });
</script>
